# =============================================================================
# NeoMessage — Environment Variables (example)
# =============================================================================
# Copy this file to .env and fill in your values.
#
# NEXT_PUBLIC_SUPABASE_URL     — Your Supabase project URL (from Settings → API)
# NEXT_PUBLIC_SUPABASE_ANON_KEY — Your Supabase anon/public key (from Settings → API)
# SUPABASE_SERVICE_ROLE_KEY    — Your Supabase service_role key (secret! for avatar uploads)
# =============================================================================

# ── Supabase (REQUIRED) ──────────────────────────────────────────────────────
# Get these from your Supabase project dashboard:
#   Project Settings → API → Project URL + anon key + service_role key
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# ── Database (Supabase managed — no separate DB needed) ────────────────────
# The Supabase project handles the PostgreSQL database automatically.
# No DATABASE_URL needed — all DB access is through the Supabase client.
